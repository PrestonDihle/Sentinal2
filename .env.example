# ============================================================
# SENTINEL2 — Environment Variables
# Copy to .env and fill in your keys
# ============================================================

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sentinel2
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=sentinel2

# Google OAuth (for Drive + Gmail)
GOOGLE_CREDENTIALS_PATH=auth/credentials.json
GOOGLE_TOKEN_PATH=auth/token.json

# Delivery — Google Drive folder IDs
SENTINEL_DRIVE_DAILY_FOLDER_ID=
SENTINEL_DRIVE_WEEKLY_FOLDER_ID=
SENTINEL_DRIVE_MONTHLY_FOLDER_ID=
SENTINEL_DRIVE_BSA_FOLDER_ID=

# Metrics API Keys
NASA_FIRMS_API_KEY=
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
ACLED_API_KEY=
ACLED_EMAIL=
YOUTUBE_API_KEY=
CLOUDFLARE_API_KEY=
ALPHA_VANTAGE_API_KEY=
OWM_API_KEY=
ZOOMEYE_API_KEY=
COPERNICUS_ADS_KEY=
BIGQUERY_PROJECT_ID=

# Optional — CrewAI memory embeddings
OPENAI_API_KEY=
